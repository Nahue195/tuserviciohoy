# ─── Base de datos ────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Ejemplo: postgresql://usuario:contraseña@localhost:5432/tuserviciohoy
DATABASE_URL="postgresql://postgres:password@localhost:5432/tuserviciohoy"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Secreto para firmar JWTs — generá uno con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secreto-super-seguro-aqui"

# URL base de la app (sin barra final)
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Creá una app en https://console.cloud.google.com/
# Callback autorizado: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxx"

# ─── Resend (magic link / email) ──────────────────────────────────────────────
# Creá cuenta en https://resend.com y generá una API Key
RESEND_API_KEY="re_xxxx"
# El email desde el que se envían los magic links (debe ser un dominio verificado en Resend)
EMAIL_FROM="TuServicioHoy <noreply@tuserviciohoy.com.ar>"

# ─── Ciudad / Configuración local ─────────────────────────────────────────────
NEXT_PUBLIC_CITY_NAME="Trenque Lauquen"

# ─── Supabase Storage (para subida de fotos) ─────────────────────────────────
# Project URL: Supabase → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
# Service role key (secreta): Supabase → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY="eyJxxxx"

# ─── MercadoPago (PLACEHOLDER — no implementado) ──────────────────────────────
# TODO: Implementar cuando se active el cobro online
# MERCADOPAGO_ACCESS_TOKEN="APP_USR-xxxx"
# MERCADOPAGO_PUBLIC_KEY="APP_USR-xxxx"

# ─── Twilio WhatsApp (PLACEHOLDER — no implementado) ──────────────────────────
# TODO: Implementar notificaciones WhatsApp
# TWILIO_ACCOUNT_SID="ACxxxx"
# TWILIO_AUTH_TOKEN="xxxx"
